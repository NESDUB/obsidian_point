[{"t":"RelevanceKit","p":"documentation/RelevanceKit","r":"Framework","a":"Provide on-device intelligence with contextual clues that increase your widget\u2019s visibility on Apple Watch.","v":{"iOS":"26.0","iPadOS":"26.0","Mac Catalyst":"26.0","macOS":"26.0","visionOS":"26.0","watchOS":"26.0"}},{"t":"RelevantContext","p":"documentation/RelevanceKit/RelevantContext","r":"Structure","a":"Contextual clues the system uses to show relevant widgets in the Smart Stack on watchOS.","v":{"iOS":"17.0","iPadOS":"17.0","Mac Catalyst":"17.0","macOS":"14.0","tvOS":"17.0","visionOS":"1.0","watchOS":"10.0"}},{"t":"RelevantContext.DateKind","p":"documentation/RelevanceKit/RelevantContext/DateKind","r":"Structure","a":"Values the system uses as additional context for time-based relevance clues.","v":{"iOS":"26.0","iPadOS":"26.0","Mac Catalyst":"26.0","macOS":"26.0","tvOS":"26.0","visionOS":"26.0","watchOS":"26.0"}},{"t":"RelevantContext.FitnessCondition","p":"documentation/RelevanceKit/RelevantContext/FitnessCondition","r":"Structure","a":"Values that represent a person\u2019s fitness activity.","v":{"iOS":"17.0","iPadOS":"17.0","Mac Catalyst":"17.0","macOS":"14.0","tvOS":"17.0","visionOS":"1.0","watchOS":"10.0"}},{"t":"RelevantContext.HeadphonesCondition","p":"documentation/RelevanceKit/RelevantContext/HeadphonesCondition","r":"Structure","a":"A structure that indicates whether a person\u2019s headphones are connected.","v":{"iOS":"17.0","iPadOS":"17.0","Mac Catalyst":"17.0","macOS":"14.0","tvOS":"17.0","visionOS":"1.0","watchOS":"10.0"}},{"t":"RelevantContext.InferredLocation","p":"documentation/RelevanceKit/RelevantContext/InferredLocation","r":"Structure","a":"A structure with values for a person\u2019s inferred home, work, school, and commute locations.","v":{"iOS":"17.0","iPadOS":"17.0","Mac Catalyst":"17.0","macOS":"14.0","tvOS":"17.0","visionOS":"1.0","watchOS":"10.0"}},{"t":"RelevantContext.SleepCondition","p":"documentation/RelevanceKit/RelevantContext/SleepCondition","r":