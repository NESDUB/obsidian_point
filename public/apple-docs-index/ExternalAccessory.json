[{"t":"EAAccessory","p":"documentation/ExternalAccessory/EAAccessory","r":"Class","a":"An object that contains information about a single, connected hardware accessory."},{"t":"EAAccessoryDelegate","p":"documentation/ExternalAccessory/EAAccessoryDelegate","r":"Protocol","a":"A protocol that defines an optional method for receiving notifications when the associated accessory object is disconnected."},{"t":"EAAccessoryDidConnectNotification","p":"documentation/ExternalAccessory/EAAccessoryDidConnectNotification","r":"Global Variable","a":"A notification that the system sends when an accessory becomes connected and available for your application to use."},{"t":"EAAccessoryDidDisconnectNotification","p":"documentation/ExternalAccessory/EAAccessoryDidDisconnectNotification","r":"Global Variable","a":"A notification that is posted when an accessory is disconnected and no longer available for your application to use."},{"t":"EAAccessoryKey","p":"documentation/ExternalAccessory/EAAccessoryKey","r":"Global Variable","a":"A key that indicates the accessory object whose status changed."},{"t":"EAAccessoryManager","p":"documentation/ExternalAccessory/EAAccessoryManager","r":"Class","a":"The object you use to identify connected accessories, and begin delivery of connection and disconnection notifications."},{"t":"EAAccessoryManager.AccessoryDidConnectMessage","p":"documentation/ExternalAccessory/EAAccessoryManager/AccessoryDidConnectMessage","r":"Structure"},{"t":"EAAccessoryManager.AccessoryDidDisconnectMessage","p":"documentation/ExternalAccessory/EAAccessoryManager/AccessoryDidDisconnectMessage","r":"Structure"},{"t":"EAAccessorySelectedKey","p":"documentation/ExternalAccessory/EAAccessorySelectedKey","r":"Global Variable","a":"A key that indicates the accessory object that the user selected."},{"t":"EABluetoothAccessoryPickerCompletion","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerCompletion","r":"Type Alias","a":"The completion block for the Bluetooth picker."},{"t":"EABluetoothAccessoryPickerError","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerError","r":"Structure","a":"Error codes returned by the Bluetooth accessory picker."},{"t":"EABluetoothAccessoryPickerError.Code","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerError/Code","r":"Enumeration","a":"The error codes that may be passed in an error object for the Bluetooth picker completion block."},{"t":"EABluetoothAccessoryPickerError.Code.alreadyConnected","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerError/Code/alreadyConnected","r":"Case","a":"The specified accessory was already connected."},{"t":"EABluetoothAccessoryPickerError.Code.resultCancelled","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerError/Code/resultCancelled","r":"Case","a":"The user canceled the picker alert."},{"t":"EABluetoothAccessoryPickerError.Code.resultFailed","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerError/Code/resultFailed","r":"Case","a":"Selecting an accessory failed for an unknown reason."},{"t":"EABluetoothAccessoryPickerError.Code.resultNotFound","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerError/Code/resultNotFound","r":"Case","a":"The specified accessory could not be found, perhaps because it was turned off prior to connection."},{"t":"EABluetoothAccessoryPickerErrorDomain","p":"documentation/ExternalAccessory/EABluetoothAccessoryPickerErrorDomain","r":"Global Variable","a":"The domain for errors passed to a Bluetooth picker completion block."},{"t":"EAConnectionIDNone","p":"documentation/ExternalAccessory/EAConnectionIDNone","r":"Global Variable"},{"t":"EASession","p":"documentation/ExternalAccessory/EASession","r":"Class","a":"The object you use to manage communications between your app and a connected hardware accessory."},{"t":"EAWiFiUnconfiguredAccessory","p":"documentation/ExternalAccessory/EAWiFiUnconfiguredAccessory","r":"Class","a":"An object that provides information 