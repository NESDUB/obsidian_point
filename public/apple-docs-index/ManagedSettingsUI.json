[{"t":"Managed Settings UI","p":"documentation/ManagedSettingsUI","r":"Framework","a":"Define and configure the appearance of shielding views."},{"t":"ShieldConfiguration","p":"documentation/ManagedSettingsUI/ShieldConfiguration","r":"Structure","a":"An object that defines the appearance of a shield to display over an application or website."},{"t":"ShieldConfiguration.Label","p":"documentation/ManagedSettingsUI/ShieldConfiguration/Label","r":"Structure","a":"The appearance of text labels within a shield."},{"t":"ShieldConfigurationDataSource","p":"documentation/ManagedSettingsUI/ShieldConfigurationDataSource","r":"Class","a":"The base class for the principal object of an app extension that configures a shield\u2019s appearance."},{"t":"backgroundBlurStyle","p":"documentation/ManagedSettingsUI/ShieldConfiguration/backgroundBlurStyle","r":"Instance Property","a":"A blur style to apply to the background of the shield."},{"t":"backgroundColor","p":"documentation/ManagedSettingsUI/ShieldConfiguration/backgroundColor","r":"Instance Property","a":"A color for a shield to use in the background blur effect."},{"t":"color","p":"documentation/ManagedSettingsUI/ShieldConfiguration/Label/color","r":"Instance Property","a":"The color of the text on a shield."},{"t":"configuration(shielding:)","p":"documentation/ManagedSettingsUI/ShieldConfigurationDataSource/configuration(shielding:)-18i24","r":"Instance Method","a":"Requests a configuration to use for a shield that covers a website."},{"t":"configuration(shielding:)","p":"documentation/ManagedSettingsUI/ShieldConfigurationDataSource/configuration(shielding:)-5uqm1","r":"Instance Method","a":"Requests a configuration to use for a shield that covers an application."},{"t":"configuration(shielding:in:)","p":"documentation/ManagedSettingsUI/ShieldConfigurationDataSource/configuration(shielding:in:)-ia14","r":"Instance Method","a":"Requests a configuration to use for a shield that covers an application because of its category."},{"t