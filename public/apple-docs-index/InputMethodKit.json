[{"t":"Anonymous","p":"documentation/InputMethodKit/inputmethodkit-enumerations-1448298-anonymous","r":"API Collection"},{"t":"Anonymous","p":"documentation/InputMethodKit/inputmethodkit-enumerations-1448301-anonymous","r":"API Collection"},{"t":"Anonymous","p":"documentation/InputMethodKit/inputmethodkit-enumerations-1448307-anonymous","r":"API Collection"},{"t":"IMKCandidatePanelType","p":"documentation/InputMethodKit/IMKCandidatePanelType","r":"Type Alias","a":"Types of candidates windows provide by the Input Method Kit."},{"t":"IMKCandidates","p":"documentation/InputMethodKit/IMKCandidates","r":"Class","a":"The `IMKCandidates` class presents candidates to users and notifies the appropriate [IMKInputController](/documentation/inputmethodkit/imkinputcontroller) object when the user selects a candidate. **Candidates** are alternate characters for a given input sequence. The `IMKCandidates` class supports using a candidates window  in your input method; using `IMKCandidates` is optional. Not all input methods require them."},{"t":"IMKCandidatesLocationHint","p":"documentation/InputMethodKit/IMKCandidatesLocationHint","r":"Type Alias","a":"Hints that suggest where to place the candidates window."},{"t":"IMKCandidatesOpacityAttributeName","p":"documentation/InputMethodKit/IMKCandidatesOpacityAttributeName","r":"Global Variable"},{"t":"IMKCandidatesSendServerKeyEventFirst","p":"documentation/InputMethodKit/IMKCandidatesSendServerKeyEventFirst","r":"Global Variable"},{"t":"IMKControllerClass","p":"documentation/InputMethodKit/IMKControllerClass","r":"Global Variable"},{"t":"IMKDelegateClass","p":"documentation/InputMethodKit/IMKDelegateClass","r":"Global Variable"},{"t":"IMKInputController","p":"documentation/InputMethodKit/IMKInputController","r":"Class","a":"The `IMKInputController` class provides a base class for custom input controller classes. The [IMKServer](/documentation/inputmethodkit/imkserver)  class, which is allocated in the main function of an input method, creates an input controller object for each input session created by a client application. For every input session there is a corresponding `IMKInputController` object."},{"t":"IMKModeDictionary","p":"documentation/InputMethodKit/IMKModeDictionary","r":"Global Variable"},{"t":"IMKMouseHandling","p":"documentation/InputMethodKit/IMKMouseHandling","r":"Protocol","a":"The `IMKMouseHandling` protocol defines methods that your input method can implement to handle mouse events."},{"t":"IMKServer","p":"documentation/InputMethodKit/IMKServer","r":"Class","a":"The `IMKServer` class manages client connections to your input method.  When you write the main function for your input method, you create an `IMKServer` object.  You should never need to override this class."},{"t":"IMKServerInput","p":"documentation/InputMethodKit/imkserverinput","r":"collectionGroup","a":"`IMKServerInput` is an informal protocol that defines methods for receiving text events. This is intentionally not a formal protocol because there are three ways to receive events. An input method chooses one of the following approaches and implements the appropriate methods:"},{"t":"IMKStateSetting","p":"documentation/InputMethodKit/IMKStateSetting","r":"Protocol","a":"The `IMKStateSetting` protocol defines methods for setting or accessing values that indicate the state of an input method."},{"t":"IMKStyleType","p":"documentation/InputMethodKit/IMKStyleType","r":"Type Alias"},{"t":"Info Dictionary Keys","p":"documentation/InputMethodKit/info-dictionary-keys","r":"API Collection","a":"Constants for keys used to look up information in the info dictionary."},{"t":"InputMethodKit","p":"documentation/InputMethodKit","r":"Framework","a":"Develop input methods and manage communication with client applications, candidates windows, and input method modes."},{"t":"InputMethodKit Constants","p":"documentation/InputMethodKit/inputmethodkit-constants","r":"API Collection"},{"t":"InputMethodKit Data Types","p":"documentation/InputMethodKit/inputmethodkit-data_types","r":"API Collection"},{"t":"InputMethodKit Enumerations","p":"documentation/InputMethodKit/inputmethodkit-enumerations","r":"collectionGroup"},{"t":"activateServer(_:)","p":"documentation/InputMethodKit/IMKStateSetting/activateServer(_:)","r":"Instance Method","a":"Activates the input method server."},{"t":"annotationSelected(_:forCandidate:)","p":"documentation/InputMethodKit/IMKInputController/annotationSelected(_:forCandidate:)","r":"Instance Method","a":"Sends the selected candidate string and annotation string to the input controller."},{"t":"attachChild(_:toCandidate:type:)","p":"documentation/InputMethodKit/IMKCandidates/attachChild(_:toCandidate:type:)","r":"Instance Method"},{"t":"attributes()","p":"documentation/InputMethodKit/IMKCandidates/attributes()","r":"Instance Method","a":"Returns a dictionary of the style attributes used for the candidates window.."},{"t":"bundle()","p":"documentation/InputMethodKit/IMKServer/bundle()","r":"Instance Method","a":"Returns an `NSBundle` object for the input method."},{"t":"cancelComposition()","p":"documentation/InputMethodKit/IMKInputController/cancelComposition()","r":"Instance Method","a":"Stops the current composition and replaces marked text with the original text."},{"t":"candidateFrame()","p":"documentation/InputMethodKit/IMKCandidates/candidateFrame()","r":"Instance Method"},{"t":"candidateIdentifier(atLineNumber:)","p":"documentation/InputMethodKit/IMKCandidates/candidateIdentifier(atLineNumber:)","r":"Instance Method"},{"t":"candidateSelected(_:)","p":"documentation/InputMethodKit/IMKInputController/candidateSelected(_:)","r":"Instance Method","a":"Informs an input controller that a new candidate is selected."},{"t":"candidateSelectionChanged(_:)","p":"documentation/InputMethodKit/IMKInputController/candidateSelectionChanged(_:)","r":"Instance Method","a":"Informs an input controller that the current candidate selection in the candidate window has changed."},{"t":"candidateStringIdentifier(_:)","p":"documentation/InputMethodKit/IMKCandidates/candidateStringIdentifier(_:)","r":"Instance Method"},{"t":"clearSelection()","p":"documentation/InputMethodKit/IMKCandidates/clearSelection()","r":"Instance Method"},{"t":"client()","p":"documentation/InputMethodKit/IMKInputController/client()","r":"Instance Method","a":"Returns the client object associated with the input controller."},{"t":"compositionAttributes(at:)","p":"documentation/InputMethodKit/IMKInputController/compositionAttributes(at:)","r":"Instance Method","a":"Returns a dictionary of text attributes."},{"t":"deactivateServer(_:)","p":"documentation/InputMethodKit/IMKStateSetting/deactivateServer(_:)","r":"Instance Method","a":"Deactivates the input method server."},{"t":"delegate()","p":"documentation/InputMethodKit/IMKInputController/delegate()","r":"Instance Method","a":"Returns the delegate for input controller  object."},{"t":"detachChild(_:)","p":"documentation/InputMethodKit/IMKCandidates/detachChild(_:)","r":"Instance Method"},{"t":"dismissesAutomatically()","p":"documentation/InputMethodKit/IMKCandidates/dismissesAutomatically()","r":"Instance Method","a":"Returns the state of the flag that determines whether the candidates window dismisses automatically."},{"t":"doCommand(by:command:)","p":"documentation/InputMethodKit/IMKInputController/doCommand(by:command:)","r":"Instance Method","a":"Passes commands that are not generated as part of the text input process."},{"t":"hide()","p":"documentation/InputMethodKit/IMKCandidates/hide()","r":"Instance Method","a":"Hides a candidates window, if it is visible."},{"t":"hideChild()","p":"documentation/InputMethodKit/IMKCandidates/hideChild()","r":"Instance Method"},{"t":"hidePalettes()","p":"documentation/InputMethodKit/IMKInputController/hidePalettes()","r":"Instance Method","a":"Informs an input method that it should  close any visible user interface."},{"t":"init(name:bundleIdentifier:)","p":"documentation/InputMethodKit/I