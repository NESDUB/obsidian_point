wserViewControllerDelegate/browserViewController(_:shouldPresentNearbyPeer:withDiscoveryInfo:)","r":"Instance Method","a":"Called when a new peer is discovered to decide whether to show it in the user interface."},{"t":"browserViewControllerDidFinish(_:)","p":"documentation/MultipeerConnectivity/MCBrowserViewControllerDelegate/browserViewControllerDidFinish(_:)","r":"Instance Method","a":"Called when the browser view controller is dismissed with peers connected in a session."},{"t":"browserViewControllerWasCancelled(_:)","p":"documentation/MultipeerConnectivity/MCBrowserViewControllerDelegate/browserViewControllerWasCancelled(_:)","r":"Instance Method","a":"Called when the user cancels the browser view controller."},{"t":"cancelConnectPeer(_:)","p":"documentation/MultipeerConnectivity/MCSession/cancelConnectPeer(_:)","r":"Instance Method","a":"Cancels an attempt to connect to a peer."},{"t":"cancelled","p":"documentation/MultipeerConnectivity/MCError/cancelled","r":"Type Property","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"connectPeer(_:withNearbyConnectionData:)","p":"documentation/MultipeerConnectivity/MCSession/connectPeer(_:withNearbyConnectionData:)","r":"Instance Method","a":"Call this method to connect a peer to the session when using your own service discovery code instead of an  `MCNearbyServiceBrowser` or `MCBrowserViewController` object."},{"t":"connectedPeers","p":"documentation/MultipeerConnectivity/MCSession/connectedPeers","r":"Instance Property","a":"An array of all peers that are currently connected to this session.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"delegate","p":"documentation/MultipeerConnectivity/MCSession/delegate","r":"Instance Property","a":"The delegate object that handles session-related events.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"delegate","p":"documentation/MultipeerConnectivity/MCNearbyServiceBrowser/delegate","r":"Instance Property","a":"The delegate object that handles browser-related events.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"delegate","p":"documentation/MultipeerConnectivity/MCNearbyServiceAdvertiser/delegate","r":"Instance Property","a":"The delegate object that handles advertising-related events.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"delegate","p":"documentation/MultipeerConnectivity/MCAdvertiserAssistant/delegate","r":"Instance Property","a":"The delegate object that handles advertising-assistant-related events.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"delegate","p":"documentation/MultipeerConnectivity/MCBrowserViewController/delegate","r":"Instance Property","a":"The delegate object that handles browser-view-controller-related events.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"disconnect()","p":"documentation/MultipeerConnectivity/MCSession/disconnect()","r":"Instance Method","a":"Disconnects the local peer from the session.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"discoveryInfo","p":"documentation/MultipeerConnectivity/MCNearbyServiceAdvertiser/discoveryInfo","r":"Instance Property","a":"The `info` dictionary passed when this object was initialized.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"discoveryInfo","p":"documentation/MultipeerConnectivity/MCAdvertiserAssistant/discoveryInfo","r":"Instance Property","a":"The `info` dictionary that was passed when this object was initialized.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"displayName","p":"documentation/MultipeerConnectivity/MCPeerID/displayName","r":"Instance Property","a":"The display name for this peer.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"encryptionPreference","p":"documentation/MultipeerConnectivity/MCSession/encryptionPreference","r":"Instance Property","a":"A value indicating whether the connection prefers encrypted connections, unencrypted connections, or has no preference.","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"errorDomain","p":"documentation/MultipeerConnectivity/MCError/errorDomain","r":"Type Property","v":{"iOS":"7.0","iPadOS":"7.0","Mac Catalyst":"13.1","macOS":"10.10","tvOS":"10.0","visionOS":"1.0"}},{"t":"init(browser:session:)","p":"documentation/MultipeerConnectivity/MCBrowserViewController/init(browser:session:)","r":"Initializer","a":"Initializes a browser view controller with the provided browser and session."},{"t":"init(coder:)","p":"documentation/MultipeerConnectivity/MCPeerID/init(coder:)","r":"Initializer"},{"t":"init(displayName:)","p":"documentation/MultipeerConnectivity/MCPeerID/init(displayName:)","r":"Initializer","a":"Initializes a peer."},{"t":"init(peer:)","p":"documentation/MultipeerConnectivity/MCSession/init(peer:)","r":"Initializer","a":"Creates a Multipeer Connectivity session."},{"t":"init(peer:discoveryInfo:serviceType:)","p":"documentation/MultipeerConnectivity/MCNearbyServiceAdvertiser/init(peer:discoveryInfo:serviceType:)","r":"Initializer","a":"Initializes an advertiser object."},{"t":"init(peer:securityIdentity:encryptionPreference:)","p":"documentation/MultipeerConnectivity/MCSession/init(peer:securityIdentity:encryptionPreference:)","r":"Initializer","a":"Creates a Multipeer Connectivity session, providing security information."},{"t":"init(peer:serviceType:)","p":"documentation/MultipeerConnectivity/MCNearbyServiceBrowser/