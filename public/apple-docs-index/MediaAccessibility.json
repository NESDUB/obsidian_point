[{"t":"Captions","p":"documentation/MediaAccessibility/captions","r":"API Collection","a":"Coordinate the presentation of closed-captioned data for your app\u2019s media files."},{"t":"Flashing lights","p":"documentation/MediaAccessibility/flashing-lights","r":"API Collection","a":"Detect, mitigate, and inform people about flashing lights in media content."},{"t":"MAAudibleMediaCopyPreferredCharacteristics()","p":"documentation/MediaAccessibility/MAAudibleMediaCopyPreferredCharacteristics()","r":"Function","a":"Returns the preference for audible media characteristics."},{"t":"MACaptionAppearanceAddSelectedLanguage(_:_:)","p":"documentation/MediaAccessibility/MACaptionAppearanceAddSelectedLanguage(_:_:)","r":"Function","a":"Adds a preference for caption language to the stack of languages."},{"t":"MACaptionAppearanceBehavior","p":"documentation/MediaAccessibility/MACaptionAppearanceBehavior","r":"Enumeration","a":"A value that indicates the preferred behavior for a preference setting."},{"t":"MACaptionAppearanceBehavior.useContentIfAvailable","p":"documentation/MediaAccessibility/MACaptionAppearanceBehavior/useContentIfAvailable","r":"Case","a":"The preference setting should be used unless the content media being played has its own custom value for this setting."},{"t":"MACaptionAppearanceBehavior.useValue","p":"documentation/MediaAccessibility/MACaptionAppearanceBehavior/useValue","r":"Case","a":"The preference setting should always be used."},{"t":"MACaptionAppearanceCopyActiveProfileID()","p":"documentation/MediaAccessibility/MACaptionAppearanceCopyActiveProfileID()","r":"Function"},{"t":"MACaptionAppearanceCopyBackgroundColor(_:_:)","p":"documentation/MediaAccessibility/MACaptionAppearanceCopyBackgroundColor(_:_:)","r":"Function","a":"Returns the preference for the text highlight color."},{"t":"MACaptionAppearanceCopyFontDescriptorForStyle(_:_:_:)","p":"documentation/MediaAccessibility/MACaptionAppearanceCopyFontDescriptorForStyle(_:_:_:)","r":"Function","a":"Retu